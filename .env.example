# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is git-ignored so your keys never leave your machine.

# ── Original OpenAI config (kept for backwards compatibility) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_JUDGE_MODEL=gpt-5-nano

# ── A+ upgrade: free-tier solver keys ──
# All three are optional. Any missing key just causes that solver to be
# skipped in the multi-solver evaluation.
CEREBRAS_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Local Ollama model overrides (optional) ──
# If you pull a stronger local model, point the generator at it here.
# OLLAMA_GENERATOR=qwen3.5:9b
# OLLAMA_SOLVER_A=qwen2.5:7b
# OLLAMA_SOLVER_B=llama3:8b
